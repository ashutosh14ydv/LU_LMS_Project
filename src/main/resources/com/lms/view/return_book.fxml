<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lms.controller.ReturnController">
   <children>
      <Label styleClass="header-text" text="Return Issued Books" />
      <TableView fx:id="tblIssued" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colId" prefWidth="50.0" text="TX ID" />
          <TableColumn fx:id="colMember" prefWidth="150.0" text="Member" />
          <TableColumn fx:id="colBook" prefWidth="180.0" text="Book Title" />
          <TableColumn fx:id="colIssueDate" prefWidth="120.0" text="Issued On" />
          <TableColumn fx:id="colDueDate" prefWidth="120.0" text="Due Date" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Label text="Set Return Date:" />
            <DatePicker fx:id="datePickerReturn" prefWidth="150.0" />
            <Pane prefWidth="20.0" />
            <Button mnemonicParsing="false" onAction="#handleReturn" prefHeight="40.0" prefWidth="120.0" styleClass="button-primary" style="-fx-background-color: #27ae60;" text="Process Return" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
