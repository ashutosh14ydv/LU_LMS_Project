<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lms.controller.BooksController">
   <children>
      <!-- Left Side: Form -->
      <VBox prefWidth="300.0" spacing="15.0" styleClass="card">
         <children>
            <Label styleClass="sub-header" text="Add / Update Book" />
            <TextField fx:id="txtTitle" promptText="Book Title" />
            <TextField fx:id="txtAuthor" promptText="Author" />
            <TextField fx:id="txtISBN" promptText="ISBN No" />
            <TextField fx:id="txtPublisher" promptText="Publisher" />
            <TextField fx:id="txtQuantity" promptText="Quantity" />
            <TextField fx:id="txtPrice" promptText="Price" />
            <HBox spacing="10.0">
               <children>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAddBook" styleClass="button-primary" text="Save Book" HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleClear" prefHeight="37.0" prefWidth="69.0" text="Clear" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
      
      <!-- Right Side: Table and Search -->
      <VBox spacing="10.0" HBox.hgrow="ALWAYS">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label styleClass="header-text" text="Book Inventory" />
                  <Pane HBox.hgrow="ALWAYS" />
                  <TextField fx:id="txtSearch" prefWidth="250.0" promptText="Search by Title / Author..." />
               </children>
            </HBox>
            <TableView fx:id="tblBooks" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
                <TableColumn fx:id="colTitle" prefWidth="150.0" text="Title" />
                <TableColumn fx:id="colAuthor" prefWidth="130.0" text="Author" />
                <TableColumn fx:id="colISBN" prefWidth="100.0" text="ISBN" />
                <TableColumn fx:id="colQuantity" prefWidth="60.0" text="Qty" />
                <TableColumn fx:id="colAvailable" prefWidth="60.0" text="Avail." />
                <TableColumn fx:id="colPrice" prefWidth="70.0" text="Price" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</HBox>
