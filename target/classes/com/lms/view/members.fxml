<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lms.controller.MembersController">
   <children>
      <VBox prefWidth="300.0" spacing="15.0" styleClass="card">
         <children>
            <Label styleClass="sub-header" text="Register Member / Student" />
            <TextField fx:id="txtName" promptText="Full Name" />
            <TextField fx:id="txtEmail" promptText="Email Address" />
            <TextField fx:id="txtPhone" promptText="Phone No" />
            <TextField fx:id="txtRollNo" promptText="Roll Number" />
            <TextArea fx:id="txtAddress" prefHeight="80.0" promptText="Address..." />
            <HBox spacing="10.0">
               <children>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAdd" styleClass="button-primary" text="Register" HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleClear" text="Clear" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
      
      <VBox spacing="10.0" HBox.hgrow="ALWAYS">
         <children>
            <Label styleClass="header-text" text="Registered Members" />
            <TableView fx:id="tblMembers" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
                <TableColumn fx:id="colName" prefWidth="150.0" text="Name" />
                <TableColumn fx:id="colRoll" prefWidth="100.0" text="Roll No" />
                <TableColumn fx:id="colEmail" prefWidth="150.0" text="Email" />
                <TableColumn fx:id="colPhone" prefWidth="120.0" text="Phone" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</HBox>
